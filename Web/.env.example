# NEXLI — environment template. Copy to .env and fill in.
# Firebase web config (public; from Firebase console → Project settings → Web app).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ImageKit (profile photos + payment QR codes).
VITE_IMAGEKIT_URL_ENDPOINT=
VITE_IMAGEKIT_PUBLIC_KEY=
VITE_IMAGEKIT_AUTH_ENDPOINT=

# Feature flags
VITE_AI_ENABLED=false

# App Check (anti-abuse). reCAPTCHA v3 SITE key (public). When set, src/lib/firebase.ts
# initializes App Check; you must also turn ON enforcement in the Firebase console.
# Leave blank for local dev (App Check stays a no-op). See docs/LAUNCH_RUNBOOK.md.
VITE_RECAPTCHA_SITE_KEY=

# Error monitoring (Sentry or equivalent). DSN for off-device crash reporting.
# When set, src/lib/monitoring.ts captures exceptions; blank = monitoring is a no-op.
# Requires installing @sentry/react and wiring monitoring.ts — see docs/LAUNCH_RUNBOOK.md.
VITE_SENTRY_DSN=
