---
import Icon from "./Icon.astro";
import { INSTAGRAM_URL, INSTAGRAM_HANDLE } from "../lib/site";
// Floating contact button. Instagram is the primary channel, so this is always a
// real, working link, never a placeholder.
---
<a
  href={INSTAGRAM_URL}
  target="_blank"
  rel="noopener"
  class="floating-ig"
  aria-label={`Message Yashveer Labs on Instagram (${INSTAGRAM_HANDLE})`}
>
  <Icon name="instagram" size={26} />
</a>

<style>
  .floating-ig {
    position: fixed;
    right: 1.1rem;
    bottom: 1.1rem;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    color: #fff;
    background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285aeb 90%);
    box-shadow: 0 14px 36px -10px rgba(214, 36, 159, 0.6);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .floating-ig:hover {
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 18px 44px -10px rgba(214, 36, 159, 0.8);
  }
  @media (min-width: 640px) {
    .floating-ig { right: 1.6rem; bottom: 1.6rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .floating-ig { transition: none; }
  }
</style>
