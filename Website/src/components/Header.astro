---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { NAV, DEMO_HREF, whatsappHref } from "../lib/site";
const wa = whatsappHref();
---
<header id="site-header" class="fixed inset-x-0 top-0 z-50 transition-colors duration-300">
  <div class="container-nx">
    <div class="flex h-[4.75rem] items-center justify-between gap-4">
      <Logo />

      <nav class="hidden items-center gap-8 lg:flex" aria-label="Primary">
        {NAV.map((item) => (
          <a
            href={item.href}
            class="text-sm text-ivory-muted transition-colors hover:text-ivory"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden items-center gap-3 sm:flex">
        <a href={DEMO_HREF} class="btn btn-ghost" style="padding:0.6rem 1.1rem;font-size:0.85rem"
          >Free Live Demo</a
        >
        <a
          href={wa}
          target="_blank"
          rel="noopener"
          class="btn btn-gold"
          style="padding:0.6rem 1.2rem;font-size:0.85rem"
        >
          <Icon name="whatsapp" size={17} />
          Contact Now
        </a>
      </div>

      <button
        id="menu-toggle"
        type="button"
        class="inline-flex items-center justify-center rounded-lg border border-line p-2 text-ivory sm:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" size={22} />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-line bg-obsidian-800/95 backdrop-blur-xl sm:hidden"
  >
    <nav class="container-nx flex flex-col gap-1 py-4" aria-label="Mobile">
      {NAV.map((item) => (
        <a
          href={item.href}
          class="rounded-lg px-3 py-3 text-ivory-muted transition-colors hover:bg-white/5 hover:text-ivory"
        >
          {item.label}
        </a>
      ))}
      <div class="mt-3 flex flex-col gap-3">
        <a href={DEMO_HREF} class="btn btn-ghost">Free Live Demo</a>
        <a href={wa} target="_blank" rel="noopener" class="btn btn-gold">
          <Icon name="whatsapp" size={18} /> Contact Now
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const header = document.getElementById("site-header");
    const onScroll = () => {
      if (!header) return;
      header.classList.toggle("is-scrolled", window.scrollY > 12);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    if (toggle && menu) {
      toggle.addEventListener("click", () => {
        const open = menu.classList.toggle("hidden") === false;
        toggle.setAttribute("aria-expanded", String(open));
        toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      });
      menu.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          menu.classList.add("hidden");
          toggle.setAttribute("aria-expanded", "false");
        })
      );
    }
  })();
</script>

<style>
  #site-header.is-scrolled {
    background: color-mix(in srgb, var(--color-obsidian-800) 82%, transparent);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--color-line);
  }
</style>
