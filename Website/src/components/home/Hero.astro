---
import Icon from "../Icon.astro";
import { DEMO_HREF, INSTAGRAM_URL, PRIMARY_CTA } from "../../lib/site";
---
<section class="relative overflow-hidden">
  <div class="glow-radial"></div>
  <div class="grid-texture"></div>

  <div class="container-nx relative pt-32 pb-16 text-center md:pt-40 md:pb-20">
    <p class="eyebrow reveal justify-center">
      <Icon name="sparkle" size={15} />
      Bringing clarity to complexity
    </p>

    <h1 class="reveal reveal-1 mx-auto mt-7 max-w-4xl">
      <span class="block text-sm font-semibold uppercase tracking-[0.4em] text-gold">Nexli</span>
      <span class="mt-4 block text-4xl leading-[1.05] sm:text-6xl md:text-[4.25rem]">
        The School Operating System
      </span>
      <span class="mt-1 block text-4xl leading-[1.05] sm:text-6xl md:text-[4.25rem]">
        <span class="text-gradient-gold">for Modern Education</span>
      </span>
    </h1>

    <p class="reveal reveal-2 mx-auto mt-7 max-w-2xl text-base text-ivory-muted sm:text-lg">
      Manage Admissions, Academics, Attendance, Fees, Compliance, Communication, Safety, HR,
      Transport, Hostel, and School Operations from a single platform.
    </p>

    <div class="reveal reveal-3 mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href={PRIMARY_CTA.href} class="btn btn-gold w-full sm:w-auto">
        <Icon name="sparkle" size={17} />
        {PRIMARY_CTA.label}
      </a>
      <a href={INSTAGRAM_URL} target="_blank" rel="noopener" class="btn btn-ghost w-full sm:w-auto">
        <Icon name="instagram" size={16} />
        Message on Instagram
      </a>
    </div>

    <p class="reveal reveal-3 mt-4 text-xs text-ivory-faint">
      Free interactive demo · No signup · India-grade compliance, built for schools everywhere
    </p>

    <!-- App preview mock -->
    <div class="reveal reveal-4 mx-auto mt-16 max-w-4xl">
      <div class="preview-frame">
        <div class="flex items-center gap-2 border-b border-line px-4 py-3">
          <span class="h-3 w-3 rounded-full" style="background:#3a3a3d"></span>
          <span class="h-3 w-3 rounded-full" style="background:#3a3a3d"></span>
          <span class="h-3 w-3 rounded-full" style="background:#3a3a3d"></span>
          <span class="ml-3 text-xs text-ivory-faint">Nexli · Principal dashboard</span>
        </div>
        <div class="p-5 text-left sm:p-7">
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
            {[
              { k: "Admissions today", v: "38", icon: "admissions" },
              { k: "Attendance", v: "96.4%", icon: "attendance" },
              { k: "Fees collected", v: "₹4.2L", icon: "fees" },
              { k: "Staff present", v: "112", icon: "hr" },
            ].map((s) => (
              <div class="rounded-xl border border-line bg-white/[0.015] p-4">
                <div class="flex items-center gap-2 text-ivory-faint">
                  <Icon name={s.icon} size={15} class="text-gold" />
                  <span class="text-[0.7rem] uppercase tracking-wider">{s.k}</span>
                </div>
                <div class="mt-2 font-display text-2xl text-ivory">{s.v}</div>
              </div>
            ))}
          </div>
          <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-3">
            <div class="rounded-xl border border-line bg-white/[0.015] p-4 sm:col-span-2">
              <div class="mb-3 text-[0.7rem] uppercase tracking-wider text-ivory-faint">
                Fee collection · last 7 days
              </div>
              <div class="flex h-24 items-end gap-2">
                {[42, 55, 38, 70, 60, 84, 48].map((h) => (
                  <div
                    class="flex-1 rounded-t"
                    style={`height:${h}%;background:linear-gradient(180deg,var(--color-gold-300),var(--color-gold-700))`}
                  ></div>
                ))}
              </div>
            </div>
            <div class="rounded-xl border border-line bg-white/[0.015] p-4">
              <div class="mb-3 text-[0.7rem] uppercase tracking-wider text-ivory-faint">Today</div>
              <ul class="space-y-2.5 text-sm text-ivory-muted">
                <li class="flex items-center gap-2"><Icon name="check" size={15} class="text-gold" /> 3 new enquiries</li>
                <li class="flex items-center gap-2"><Icon name="check" size={15} class="text-gold" /> PTM scheduled</li>
                <li class="flex items-center gap-2"><Icon name="check" size={15} class="text-gold" /> Bus 12 on route</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
      <p class="mt-3 text-center text-[0.7rem] text-ivory-faint">Illustrative preview · figures are sample data</p>
    </div>
  </div>
</section>
