---
import Icon from "../Icon.astro";
import { DEMO_HREF, whatsappHref } from "../../lib/site";
const wa = whatsappHref();
---
<section class="section">
  <div class="container-nx">
    <div class="relative overflow-hidden rounded-3xl border border-line px-6 py-16 text-center sm:px-12">
      <div class="glow-radial"></div>
      <div class="relative">
        <p class="eyebrow reveal justify-center">Get started</p>
        <h2 class="reveal reveal-1 mx-auto mt-5 max-w-2xl text-3xl sm:text-4xl md:text-5xl">
          Ready to bring clarity to your school?
        </h2>
        <p class="reveal reveal-2 mx-auto mt-5 max-w-xl text-ivory-muted">
          Talk to us on WhatsApp and we'll show you exactly how Nexli fits your school — or book a
          free live demo at your convenience.
        </p>
        <div class="reveal reveal-3 mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href={wa} target="_blank" rel="noopener" class="btn btn-gold w-full sm:w-auto">
            <Icon name="whatsapp" size={18} />
            Contact Now
          </a>
          <a href={DEMO_HREF} class="btn btn-ghost w-full sm:w-auto">
            Free Live Demo
            <Icon name="arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
