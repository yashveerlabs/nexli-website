---
import Icon from "../Icon.astro";
import { MODULES } from "../../lib/site";
---
<section id="platform" class="section">
  <div class="container-nx">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow reveal justify-center">One platform</p>
      <h2 class="reveal reveal-1 mt-5 text-3xl sm:text-4xl md:text-5xl">
        Every school operation, in one place
      </h2>
      <p class="reveal reveal-2 mt-5 text-ivory-muted">
        Nexli replaces a drawer full of disconnected tools with a single, role-aware system,
        purpose-built for how Indian schools actually run.
      </p>
    </div>

    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {MODULES.map((m) => (
        <article class="card reveal">
          <div
            class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-line text-gold"
            style="background:rgba(198,165,92,0.06)"
          >
            <Icon name={m.icon} size={21} />
          </div>
          <h3 class="mt-5 text-lg text-ivory">{m.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ivory-muted">{m.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
