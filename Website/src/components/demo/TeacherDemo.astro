---
import DemoShell from "./DemoShell.astro";
import Icon from "../Icon.astro";
import { CLASS_ROSTER, HOMEWORK } from "../../lib/demo-data";

const screens = [
  { id: "class", label: "Class dashboard", icon: "academics" },
  { id: "attendance", label: "Take attendance", icon: "attendance" },
  { id: "marks", label: "Enter marks", icon: "check" },
  { id: "homework", label: "Homework", icon: "book" },
];
const present0 = CLASS_ROSTER.filter((s) => s.attendance >= 75).length;
const avgAttendance = Math.round(CLASS_ROSTER.reduce((a, s) => a + s.attendance, 0) / CLASS_ROSTER.length);
const classAvg = Math.round(CLASS_ROSTER.reduce((a, s) => a + s.avg, 0) / CLASS_ROSTER.length);
const dueCount = CLASS_ROSTER.filter((s) => s.fees === "Due").length;
---
<DemoShell role="teacher" title="Teacher · Class 8-B" screens={screens}>
  <!-- Class dashboard -->
  <section class="demo-screen" data-screen="class">
    <h2 class="text-2xl">Class 8 — B</h2>
    <p class="mt-1 text-sm text-ivory-muted">Your class at a glance.</p>
    <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="demo-panel"><span class="text-xs text-ivory-faint">Class strength</span><div class="demo-stat-value mt-3">{CLASS_ROSTER.length}</div></div>
      <div class="demo-panel"><span class="text-xs text-ivory-faint">Avg attendance</span><div class="demo-stat-value mt-3">{avgAttendance}%</div></div>
      <div class="demo-panel"><span class="text-xs text-ivory-faint">Class average</span><div class="demo-stat-value mt-3">{classAvg}%</div></div>
      <div class="demo-panel"><span class="text-xs text-ivory-faint">Fees due</span><div class="demo-stat-value mt-3">{dueCount}</div></div>
    </div>
    <div class="demo-panel mt-4">
      <h3 class="text-sm text-ivory">Students</h3>
      <div class="mt-3 overflow-x-auto">
        <table class="demo-table">
          <thead><tr><th>Roll</th><th>Name</th><th>Attendance</th><th>Average</th><th>Fees</th></tr></thead>
          <tbody>
            {CLASS_ROSTER.map((s) => (
              <tr>
                <td>{s.roll}</td>
                <td class="text-ivory">{s.name}</td>
                <td><span class={`badge ${s.attendance < 75 ? "badge-bad" : "badge-good"}`}>{s.attendance}%</span></td>
                <td>{s.avg}%</td>
                <td><span class={`badge ${s.fees === "Due" ? "badge-warn" : "badge-good"}`}>{s.fees}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Take attendance (interactive) -->
  <section class="demo-screen" data-screen="attendance" hidden>
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="text-2xl">Take attendance</h2>
        <p class="mt-1 text-sm text-ivory-muted">Tap a student to toggle present / absent. Period 1 · Mathematics.</p>
      </div>
      <div class="demo-panel !py-3 text-center">
        <span class="text-xs text-ivory-faint">Present</span>
        <div class="demo-stat-value mt-1"><span data-present-count>{present0}</span> / {CLASS_ROSTER.length}</div>
      </div>
    </div>
    <div class="mt-5 grid gap-2.5 sm:grid-cols-2">
      {CLASS_ROSTER.map((s) => (
        <button type="button" class="flex items-center justify-between rounded-xl border border-line px-4 py-3 text-left transition-colors hover:border-gold/30" data-att-btn data-present={s.attendance >= 75 ? "1" : "0"}>
          <span class="flex items-center gap-3">
            <span class="inline-grid h-8 w-8 place-items-center rounded-full border border-line text-xs text-ivory-muted">{s.roll}</span>
            <span class="text-sm text-ivory">{s.name}</span>
          </span>
          <span class="badge" data-att-pill>—</span>
        </button>
      ))}
    </div>
    <div class="mt-5">
      <button type="button" class="btn btn-gold" data-att-save style="padding:0.6rem 1.3rem"><Icon name="check" size={16} /> Save attendance</button>
      <span class="ml-3 text-xs text-ivory-faint" data-att-saved hidden>Saved · parents of absentees notified (demo)</span>
    </div>
  </section>

  <!-- Enter marks (interactive) -->
  <section class="demo-screen" data-screen="marks" hidden>
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="text-2xl">Enter marks</h2>
        <p class="mt-1 text-sm text-ivory-muted">Unit Test 2 · Mathematics · out of 25. Type a score to see the class average update.</p>
      </div>
      <div class="demo-panel !py-3 text-center">
        <span class="text-xs text-ivory-faint">Class average</span>
        <div class="demo-stat-value mt-1"><span data-marks-avg>—</span> / 25</div>
      </div>
    </div>
    <div class="demo-panel mt-5">
      <div class="overflow-x-auto">
        <table class="demo-table">
          <thead><tr><th>Roll</th><th>Name</th><th style="width:7rem">Marks /25</th></tr></thead>
          <tbody>
            {CLASS_ROSTER.map((s) => (
              <tr>
                <td>{s.roll}</td>
                <td class="text-ivory">{s.name}</td>
                <td><input type="number" min="0" max="25" inputmode="numeric" class="nx-input !py-1.5 !px-2.5" style="width:5rem" data-mark-input value={Math.round((s.avg / 100) * 25)} /></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Homework -->
  <section class="demo-screen" data-screen="homework" hidden>
    <h2 class="text-2xl">Homework</h2>
    <p class="mt-1 text-sm text-ivory-muted">What's assigned this week, and who has submitted.</p>
    <div class="mt-5 space-y-4">
      {HOMEWORK.map((h) => (
        <div class="demo-panel">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <div>
              <span class="badge badge-good">{h.subject}</span>
              <h3 class="mt-2 text-ivory">{h.title}</h3>
            </div>
            <span class="text-xs text-ivory-faint">Due {h.due}</span>
          </div>
          <div class="mt-3 flex items-center gap-3">
            <div class="demo-bar-track flex-1"><div class="demo-bar-fill" style={`width:${Math.round((h.submitted / h.total) * 100)}%`}></div></div>
            <span class="text-xs text-ivory-muted">{h.submitted}/{h.total} submitted</span>
          </div>
        </div>
      ))}
    </div>
  </section>
</DemoShell>

<script is:inline>
  (function () {
    // Take attendance toggles
    const countEl = document.querySelector("[data-present-count]");
    const btns = Array.from(document.querySelectorAll("[data-att-btn]"));
    function paint(btn) {
      const present = btn.getAttribute("data-present") === "1";
      const pill = btn.querySelector("[data-att-pill]");
      pill.textContent = present ? "Present" : "Absent";
      pill.className = "badge " + (present ? "badge-good" : "badge-bad");
    }
    function recount() {
      if (countEl) countEl.textContent = btns.filter((b) => b.getAttribute("data-present") === "1").length;
    }
    btns.forEach((b) => {
      paint(b);
      b.addEventListener("click", () => {
        b.setAttribute("data-present", b.getAttribute("data-present") === "1" ? "0" : "1");
        paint(b);
        recount();
      });
    });
    recount();
    const save = document.querySelector("[data-att-save]");
    const saved = document.querySelector("[data-att-saved]");
    if (save && saved) save.addEventListener("click", () => { saved.hidden = false; });

    // Enter marks → live average
    const inputs = Array.from(document.querySelectorAll("[data-mark-input]"));
    const avgEl = document.querySelector("[data-marks-avg]");
    function recompute() {
      const vals = inputs.map((i) => parseFloat(i.value)).filter((v) => !isNaN(v));
      if (avgEl) avgEl.textContent = vals.length ? (vals.reduce((a, b) => a + b, 0) / vals.length).toFixed(1) : "—";
    }
    inputs.forEach((i) => i.addEventListener("input", recompute));
    recompute();
  })();
</script>
