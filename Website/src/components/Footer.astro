---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { SITE, FOOTER_GROUPS, INSTAGRAM_URL, whatsappHref } from "../lib/site";
const wa = whatsappHref();
const year = new Date().getFullYear();
---
<footer class="relative border-t border-line">
  <div class="container-nx py-16">
    <div class="grid gap-12 md:grid-cols-[1.6fr_1fr_1fr_1fr_1fr]">
      <div>
        <Logo />
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-ivory-muted">
          The School Operating System for modern education. {SITE.tagline}.
        </p>
        <a href={wa} target="_blank" rel="noopener" class="btn btn-whatsapp mt-6">
          <Icon name="whatsapp" size={18} /> Contact on WhatsApp
        </a>
        <div class="mt-5 flex items-center gap-3">
          <a
            href={INSTAGRAM_URL}
            target="_blank"
            rel="noopener"
            aria-label="Yashveer Labs on Instagram"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-ivory-muted transition-colors hover:border-gold/50 hover:text-gold-200"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="3.6" />
              <circle cx="17.4" cy="6.6" r="0.9" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <span class="text-xs text-ivory-faint">@yashveerlabs</span>
        </div>
      </div>

      {FOOTER_GROUPS.map((group) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-ivory-faint">{group.heading}</h3>
          <ul class="mt-4 space-y-3 text-sm">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="text-ivory-muted transition-colors hover:text-gold-200">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <hr class="hairline my-10" />

    <div class="flex flex-col items-center justify-between gap-4 text-sm text-ivory-faint sm:flex-row">
      <p>© {year} {SITE.name} · {SITE.company}. All rights reserved.</p>
      <p class="flex items-center gap-2">
        <Icon name="sparkle" size={14} class="text-gold" />
        Built for Indian schools · Made in India
      </p>
    </div>
  </div>
</footer>
