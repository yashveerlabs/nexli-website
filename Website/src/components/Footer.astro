---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { SITE, FOOTER_GROUPS, SOCIALS, LOCATION, INSTAGRAM_URL, INSTAGRAM_HANDLE } from "../lib/site";
const year = new Date().getFullYear();
---
<footer class="relative border-t border-line">
  <div class="container-nx py-16">
    <div class="grid gap-12 md:grid-cols-[1.6fr_1fr_1fr_1fr_1fr]">
      <div>
        <Logo />
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-ivory-muted">
          The School Operating System for modern education. {SITE.tagline}.
        </p>

        <!-- Primary contact: Instagram -->
        <a href={INSTAGRAM_URL} target="_blank" rel="noopener" class="btn btn-instagram mt-6">
          <Icon name="instagram" size={18} /> Message us on Instagram
        </a>

        <!-- Location + email -->
        <div class="mt-5 space-y-1.5 text-sm text-ivory-muted">
          <p class="flex items-center gap-2">
            <Icon name="pin" size={15} class="text-gold" /> {LOCATION}
          </p>
        </div>

        <!-- Social row: only real, owner-confirmed profiles -->
        <div class="mt-5 flex flex-wrap items-center gap-2.5">
          {SOCIALS.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              aria-label={`Yashveer Labs on ${s.label}`}
              class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-ivory-muted transition-colors hover:border-gold/50 hover:text-gold-200"
            >
              <Icon name={s.icon} size={16} />
            </a>
          ))}
        </div>
        <p class="mt-3 text-xs text-ivory-faint">{INSTAGRAM_HANDLE} on every platform</p>
      </div>

      {FOOTER_GROUPS.map((group) => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-ivory-faint">{group.heading}</h3>
          <ul class="mt-4 space-y-3 text-sm">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="text-ivory-muted transition-colors hover:text-gold-200">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <hr class="hairline my-10" />

    <div class="flex flex-col items-center justify-between gap-4 text-sm text-ivory-faint sm:flex-row">
      <p>© {year} {SITE.company}. All Rights Reserved.</p>
      <p class="flex items-center gap-2">
        <Icon name="sparkle" size={14} class="text-gold" />
        Made in India · Built for schools everywhere
      </p>
    </div>
  </div>
</footer>
