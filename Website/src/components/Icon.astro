const isFilled = name in filled;
const inner = isFilled ? filled[name] : (stroke[name] ?? "");
---
{isFilled ? (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="currentColor"
    class={className}
    aria-hidden="true"
    focusable="false"
    set:html={inner}
  />
) : (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    class={className}
    aria-hidden="true"
    focusable="false"
    set:html={inner}
  />
)}
