  transport:
    '<rect x="3" y="4.5" width="18" height="12" rx="2.5"/><line x1="3" y1="11" x2="21" y2="11"/><circle cx="7.5" cy="19" r="1.4"/><circle cx="16.5" cy="19" r="1.4"/><line x1="7" y1="16.5" x2="7" y2="18"/><line x1="17" y1="16.5" x2="17" y2="18"/>',
