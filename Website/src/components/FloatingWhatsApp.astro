---
import Icon from "./Icon.astro";
import { whatsappHref } from "../lib/site";
const wa = whatsappHref();
---
<a
  href={wa}
  target="_blank"
  rel="noopener"
  class="floating-wa"
  aria-label="Contact Nexli on WhatsApp"
>
  <Icon name="whatsapp" size={28} />
</a>

<style>
  .floating-wa {
    position: fixed;
    right: 1.1rem;
    bottom: 1.1rem;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    background: #1faa53;
    color: #fff;
    box-shadow: 0 14px 36px -10px rgba(31, 170, 83, 0.7);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }
  .floating-wa:hover {
    transform: translateY(-2px) scale(1.04);
    background: #23bd5c;
    box-shadow: 0 18px 44px -10px rgba(31, 170, 83, 0.85);
  }
  @media (min-width: 640px) {
    .floating-wa { right: 1.6rem; bottom: 1.6rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    .floating-wa { transition: none; }
  }
</style>
