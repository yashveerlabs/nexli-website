---
// Injects one or more JSON-LD blocks. Pass a single object or an array.
interface Props {
  schema: Record<string, any> | Record<string, any>[];
}
const { schema } = Astro.props;
const blocks = Array.isArray(schema) ? schema : [schema];
---
{blocks.map((block) => (
  <script type="application/ld+json" set:html={JSON.stringify(block)} is:inline />
))}
