---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import {
  SITE,
  INSTAGRAM_URL,
  INSTAGRAM_HANDLE,
  CONTACT_EMAIL,
  EMAIL_HREF,
  DEMO_HREF,
  PRIMARY_CTA,
  FOUNDER_SAME_AS,
  SOCIALS,
} from "../lib/site";
import { abs } from "../lib/seo";

const title = "Yashveer Singh Rajpoot: Founder & Lead Engineer";
const description =
  "Yashveer Singh Rajpoot is the founder of Yashveer Labs and the Founder & Lead Engineer of Nexli, the School Operating System: one platform for admissions, academics, fees, attendance, compliance and operations, built for schools worldwide.";

// Person JSON-LD for entity recognition (so a search for "Yashveer Singh Rajpoot"
// resolves to the founder of Yashveer Labs and Founder & Lead Engineer of Nexli).
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Yashveer Singh Rajpoot",
  jobTitle: "Founder & Lead Engineer",
  description:
    "Founder of Yashveer Labs and Founder & Lead Engineer of Nexli, the School Operating System for modern education, built for schools worldwide.",
  url: abs("/founder"),
  image: abs("/founder.jpg"),
  worksFor: {
    "@type": "Organization",
    name: "Yashveer Labs",
    url: SITE.url,
  },
  knowsAbout: [
    "School management software",
    "Education technology",
    "School Operating System",
    "Software engineering",
  ],
  sameAs: FOUNDER_SAME_AS,
};

// Profiles to surface as quick links on the page (subset, with handles where set).
const profileLinks = SOCIALS.filter((s) =>
  ["Instagram", "X", "LinkedIn", "GitHub", "Medium"].includes(s.label)
);

const built = [
  { icon: "globe", title: "He built it for schools anywhere, India-grade at the core", desc: "Nexli began with the hardest compliance in the world, DPDP, POCSO and RTE, and the realities of schools where paper still matters and connectivity isn't guaranteed. Solve for that, and a school in any country can run on it." },
  { icon: "analytics", title: "He designed around the principal's view", desc: "The question that shaped the system was \"what does a principal need to know in two minutes?\" Every other role's dashboard followed from that." },
  { icon: "safety", title: "He made child safety the default", desc: "Student-to-student messaging off by default, medical data encrypted, counselling notes in a restricted locker, POCSO complaints escalating automatically: decisions made at the architecture level." },
  { icon: "operations", title: "He built it to be configured, not coded", desc: "Even the role system is data-driven. A school can add roles, change permissions and adjust workflows without waiting for a developer." },
];
---
<BaseLayout title={title} description={description} jsonLd={personJsonLd}>
  <section class="relative overflow-hidden border-b border-line">
    <div class="glow-radial"></div>
    <div class="grid-texture"></div>
    <div class="container-nx relative pb-16 pt-32 md:pt-40">
      <Breadcrumbs items={[{ label: "Company", href: "/about" }, { label: "Founder" }]} class="mb-8" />
      <div class="grid items-center gap-12 lg:grid-cols-[1fr_1.4fr]">
        <!-- Portrait -->
        <div class="order-1 lg:order-none">
          <div class="relative mx-auto aspect-square w-full max-w-sm overflow-hidden rounded-[1.75rem] border border-line" style="background:linear-gradient(160deg,var(--color-obsidian-700),var(--color-obsidian-800))">
            <img
              src="/founder.jpg"
              alt="Yashveer Singh Rajpoot, Founder & Lead Engineer of Nexli and founder of Yashveer Labs"
              width="640"
              height="640"
              loading="eager"
              class="h-full w-full object-cover"
            />
          </div>
        </div>

        <div>
          <p class="eyebrow">Founder</p>
          <h1 class="mt-4 text-4xl leading-tight md:text-6xl">Yashveer Singh Rajpoot</h1>
          <p class="mt-3 text-lg text-gold-200">Founder &amp; Lead Engineer, Nexli · Founder, Yashveer Labs</p>
          <p class="mt-6 max-w-xl text-lg text-ivory-muted">
            Yashveer Singh Rajpoot is the founder of Yashveer Labs and the Founder &amp; Lead Engineer of
            Nexli, the School Operating System. He designed and built Nexli from the ground up: one platform
            that brings a school's admissions, academics, attendance, fees, compliance, safety and operations
            into a single, calm system.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={INSTAGRAM_URL} target="_blank" rel="noopener" class="btn btn-instagram">
              <Icon name="instagram" size={18} /> Message {INSTAGRAM_HANDLE}
            </a>
            <a href={PRIMARY_CTA.href} class="btn btn-ghost">
              <Icon name="sparkle" size={16} /> {PRIMARY_CTA.label}
            </a>
          </div>
          <div class="mt-6 flex flex-wrap items-center gap-2.5">
            {profileLinks.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener"
                aria-label={`Yashveer Singh Rajpoot on ${s.label}`}
                class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-ivory-muted transition-colors hover:border-gold/50 hover:text-gold-200"
              >
                <Icon name={s.icon} size={16} />
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Narrative -->
  <section class="section">
    <div class="container-nx">
      <div class="mx-auto max-w-3xl">
        <div class="prose-nx">
          <p>Nexli did not begin as a company. It began as a problem Yashveer Singh Rajpoot kept watching up close inside his own school: capable people, an admissions team, accountants, class teachers, a principal, all doing their jobs well, yet losing hours every day to tools that didn't talk to each other. The work wasn't the bottleneck. The coordination was.</p>
          <p>Most school software is built by engineers who have never sat inside a school office, so the details get missed and the workflows feel imposed from the outside. Yashveer built Nexli the opposite way, by treating a timetable as a communication tool, attendance as an early-warning system, and fees as a window into a school's health. As Founder and Lead Engineer he wrote the architecture himself, which is why the decisions that matter, security, child safety, and a role system you configure instead of code, sit at the foundation rather than bolted on later.</p>
          <p>The idea was born in an Indian school, but it was never meant to stop there. Schools everywhere fight the same fragmentation, and they all answer to demanding regulators, parents and boards. So Nexli was built for the hardest case first, India-grade compliance and connectivity, and designed so that an educational institution anywhere in the world can run on it. Yashveer Labs, the studio behind it, exists on a single principle its founder ships everything by: technology should remove obstacles, not create them.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What he built -->
  <section class="section pt-0">
    <div class="container-nx">
      <div class="max-w-2xl">
        <p class="eyebrow">What he built, and why</p>
        <h2 class="reveal mt-3 text-3xl md:text-4xl">Decisions you can see in the product</h2>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2">
        {built.map((b, i) => (
          <div class={`card reveal reveal-${(i % 4) + 1}`}>
            <span class="inline-grid h-11 w-11 place-items-center rounded-xl border border-line text-gold" style="background:rgba(255,255,255,0.02)">
              <Icon name={b.icon} size={20} />
            </span>
            <h3 class="mt-4 text-lg text-ivory">{b.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ivory-muted">{b.desc}</p>
          </div>
        ))}
      </div>

      <p class="mt-8 text-sm text-ivory-muted">
        Reach Yashveer directly on
        <a href={INSTAGRAM_URL} target="_blank" rel="noopener" class="text-gold-200 underline-offset-2 hover:underline">Instagram</a>
        or by email at
        <a href={EMAIL_HREF} class="text-gold-200 underline-offset-2 hover:underline">{CONTACT_EMAIL}</a>.
      </p>
    </div>
  </section>

  <CtaBand
    eyebrow="From the founder"
    title="Want to talk directly?"
    text="If you lead a school and care about doing things right, Yashveer would like to hear from you. Try the live demo, then send a message on Instagram and start a real conversation."
  />
</BaseLayout>
