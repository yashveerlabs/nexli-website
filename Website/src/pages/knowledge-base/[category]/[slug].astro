---
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import Faq from "../../../components/Faq.astro";
import Icon from "../../../components/Icon.astro";
import { INSTAGRAM_URL } from "../../../lib/site";
import { getAllArticles, extractFaqs, relatedArticles } from "../../../lib/kb";
import { brandingFor } from "../../../lib/branding-blocks";
import { articleSchema } from "../../../lib/seo";

export async function getStaticPaths() {
  const all = await getAllArticles();
  return all.map((a) => ({ params: { category: a.categorySlug, slug: a.slug } }));
}

const { category, slug } = Astro.params;
const all = await getAllArticles();
const article = all.find((a) => a.categorySlug === category && a.slug === slug)!;
const path = `/knowledge-base/${article.categorySlug}/${article.slug}`;

const { Content, headings } = await render(article.entry);
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const faqs = extractFaqs(article.entry.body || "");
const branding = brandingFor(article.branding, article.seed);
const related = relatedArticles(article, all, 4);

const jsonLd = articleSchema({
  title: article.title,
  description: article.description,
  path,
  datePublished: article.date,
  author: article.author,
});
---
<BaseLayout title={article.title} description={article.description} jsonLd={jsonLd}>
  <!-- Article header -->
  <section class="relative overflow-hidden border-b border-line">
    <div class="glow-radial"></div>
    <div class="container-nx relative pb-10 pt-32 md:pt-40">
      <Breadcrumbs items={[{ label: "Knowledge Base", href: "/knowledge-base" }, { label: article.categoryTitle, href: `/knowledge-base/${article.categorySlug}` }, { label: article.title }]} class="mb-6" />
      <div class="max-w-3xl">
        <a href={`/knowledge-base/${article.categorySlug}`} class="kicker-chip"><Icon name="book" size={13} /> {article.categoryTitle}</a>
        <h1 class="mt-5 text-3xl leading-[1.1] md:text-5xl">{article.title}</h1>
        <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-ivory-faint">
          <span>{article.readingTime} min read</span>
          <span aria-hidden="true">·</span>
          <span>By {article.author}</span>
          {article.date && (<><span aria-hidden="true">·</span><span>Updated {article.date}</span></>)}
        </div>
      </div>
    </div>
  </section>

  <!-- Body + TOC -->
  <section class="section">
    <div class="container-nx">
      <div class="grid gap-12 lg:grid-cols-[1fr_15rem] lg:gap-14">
        <article class="min-w-0">
          <div class="prose-nx max-w-none">
            <Content />
          </div>

          <!-- In-article demo CTA -->
          <div class="callout mt-12">
            <p class="eyebrow"><Icon name="sparkle" size={14} /> See it in Nexli</p>
            <h2 class="mt-3 text-2xl">From guide to practice</h2>
            <p class="mt-2 text-ivory-muted">This is exactly the kind of work Nexli is built to handle. Open the interactive demo, no signup needed, or message us about your school.</p>
            <div class="mt-5 flex flex-col gap-3 sm:flex-row">
              <a href="/demo" class="btn btn-gold">Try the live demo</a>
              <a href={INSTAGRAM_URL} target="_blank" rel="noopener" class="btn btn-ghost">
                <Icon name="instagram" size={17} /> Message on Instagram
              </a>
            </div>
          </div>

          <!-- Canonical branding blocks -->
          {(branding.founder || branding.company || branding.nexli) && (
            <div class="mt-10 space-y-4">
              {branding.founder && (
                <div class="callout">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gold">About Yashveer Singh</p>
                  <p class="mt-2 text-sm leading-relaxed text-ivory-muted">{branding.founder}</p>
                </div>
              )}
              {branding.company && (
                <div class="callout">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gold">About Yashveer Labs</p>
                  <p class="mt-2 text-sm leading-relaxed text-ivory-muted">{branding.company}</p>
                </div>
              )}
              {branding.nexli && (
                <div class="callout">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gold">How Nexli helps</p>
                  <p class="mt-2 text-sm leading-relaxed text-ivory-muted">{branding.nexli}</p>
                </div>
              )}
            </div>
          )}
        </article>

        <!-- TOC -->
        {toc.length >= 3 && (
          <aside class="hidden lg:block">
            <div class="sticky top-28">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ivory-faint">On this page</p>
              <nav class="mt-4 border-l border-line" aria-label="Table of contents">
                <ul class="space-y-1 text-sm">
                  {toc.map((h) => (
                    <li>
                      <a href={`#${h.slug}`} class={`block border-l border-transparent py-1 transition-colors hover:text-gold-200 ${h.depth === 3 ? "pl-6 text-ivory-faint" : "pl-4 text-ivory-muted"}`} style="margin-left:-1px">{h.text}</a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          </aside>
        )}
      </div>
    </div>
  </section>

  <!-- Related -->
  {related.length > 0 && (
    <section class="section pt-0">
      <div class="container-nx">
        <div class="flex items-end justify-between gap-4">
          <h2 class="text-2xl md:text-3xl">Related guides</h2>
          <a href={`/knowledge-base/${article.categorySlug}`} class="hidden items-center gap-1.5 text-sm text-gold transition-transform hover:translate-x-1 sm:inline-flex">
            More in {article.categoryTitle} <Icon name="arrow-right" size={15} />
          </a>
        </div>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {related.map((a, i) => <ArticleCard article={a} index={i} />)}
        </div>
      </div>
    </section>
  )}

  <Faq items={faqs} title="Frequently asked questions" eyebrow="FAQ" />
</BaseLayout>
