---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import CtaBand from "../components/CtaBand.astro";
import { ROLES, SCHOOL } from "../lib/demo-data";
import { webPage } from "../lib/seo";

const title = "Live Demo";
const description =
  "Explore Nexli as a Principal, Teacher, Student, Parent and more — an interactive demo of Nexli Demo School with sample data. No signup, no login, no email.";
---
<BaseLayout title={title} description={description} jsonLd={webPage({ title, description, path: "/demo" })}>
  <PageHero
    eyebrow="Live Demo"
    title="Step inside Nexli"
    lead={`Pick a role and explore ${SCHOOL.name} as that person would see it. It's interactive, it's the real design system, and it runs entirely in your browser.`}
    breadcrumbs={[{ label: "Live Demo" }]}
  >
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ivory-faint">
      <span class="flex items-center gap-2"><Icon name="check" size={15} class="text-gold" /> No signup</span>
      <span class="flex items-center gap-2"><Icon name="check" size={15} class="text-gold" /> No login</span>
      <span class="flex items-center gap-2"><Icon name="check" size={15} class="text-gold" /> No email</span>
    </div>
  </PageHero>

  <section class="section">
    <div class="container-nx">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {ROLES.map((r, i) => (
          <a href={`/demo/${r.slug}`} class={`card group reveal reveal-${(i % 4) + 1} flex flex-col`}>
            <div class="flex items-start justify-between gap-3">
              <span class="inline-grid h-12 w-12 place-items-center rounded-xl border border-line text-gold" style="background:rgba(255,255,255,0.02)">
                <Icon name={r.icon} size={22} />
              </span>
              <Icon name="arrow-right" size={18} class="text-ivory-faint transition-all group-hover:translate-x-1 group-hover:text-gold" />
            </div>
            <h2 class="mt-4 text-xl text-ivory">{r.title}</h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-ivory-muted">{r.blurb}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm text-gold">Enter as {r.title} →</span>
          </a>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-ivory-faint">
        Everything you'll see is <span class="text-ivory-muted">sample data for a fictional school</span> — no real students, no backend, nothing saved.
      </p>
    </div>
  </section>

  <CtaBand
    eyebrow="Prefer a guided tour?"
    title="Want a real demo for your school?"
    text="The interactive demo is a taste. For a walkthrough with your own school's context, message us on WhatsApp and we'll set up a live session."
  />
</BaseLayout>
