---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { webPage } from "../lib/seo";

const title = "About Nexli";
const description =
  "Nexli is the School Operating System built by Yashveer Labs: one calm, connected platform for Indian schools. Our philosophy: clarity over complexity, systems over chaos.";

const principles = [
  { icon: "sparkle", title: "Clarity over complexity", desc: "Schools are complex enough. Software shouldn't add to it. Nexli hides the machinery and shows each person exactly what they need, in two minutes, not twenty clicks." },
  { icon: "operations", title: "Systems over chaos", desc: "Most school problems aren't effort problems; they're coordination problems. Nexli replaces scattered tools and registers with one system, so the school runs on a single source of truth." },
  { icon: "shield", title: "India-first, not adapted", desc: "Indian schools are not smaller versions of Western institutions. Nexli is built from the ground up for their regulations, formats and realities: DPDP, POCSO, RTE, CBSE, UDISE+." },
  { icon: "hr", title: "Built by people who listened", desc: "Nexli is shaped by time spent with class teachers, accountants, principals and parents, not by a whiteboard. The features exist because real schools needed them." },
];

const facts = [
  { k: "118+", v: "configurable roles, each with its own permissions" },
  { k: "12", v: "modules covering the whole school day" },
  { k: "India", v: "data hosted close to home, DPDP-aligned" },
];
---
<BaseLayout title={title} description={description} jsonLd={webPage({ title, description, path: "/about" })}>
  <PageHero
    eyebrow="About Nexli"
    title="The system underneath a calmer school"
    lead="Nexli is the School Operating System for modern education, one connected platform that brings clarity to the complexity of running an Indian school."
    breadcrumbs={[{ label: "About" }]}
  />

  <!-- Story -->
  <section class="section">
    <div class="container-nx">
      <div class="mx-auto max-w-3xl">
        <p class="eyebrow">The story</p>
        <div class="prose-nx mt-5">
          <p>Nexli wasn't built inside a boardroom. It was built from the outside in, from watching how Indian schools actually run, and how much of a good educator's day is lost to coordinating tools instead of teaching.</p>
          <p>A principal might be responsible for thousands of students, hundreds of staff, finance, compliance, transport and safety, all at once. What breaks people isn't the number of tasks. It's the fragmentation: attendance in one system, fees in another, compliance notices buried in email, and the truth scattered across a dozen places that never quite agree.</p>
          <p>So the question behind Nexli was a simple one: <strong>why should schools operate this way?</strong> Rather than accept the answer, we built a platform where every role, from the classroom teacher to the chairman, sees exactly what they need, and nothing they shouldn't. Where attendance is an early-warning system, fees are a window into the school's health, and compliance is a byproduct of doing the ordinary work well.</p>
          <p>That's what an operating system does: it hides the complexity, provides one interface, and lets you focus on the real work. Nexli applies that idea to the whole school.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="section pt-0">
    <div class="container-nx">
      <div class="max-w-2xl">
        <p class="eyebrow">What we believe</p>
        <h2 class="reveal mt-3 text-3xl md:text-4xl">The philosophy behind the product</h2>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2">
        {principles.map((p, i) => (
          <div class={`card reveal reveal-${(i % 4) + 1}`}>
            <span class="inline-grid h-11 w-11 place-items-center rounded-xl border border-line text-gold" style="background:rgba(255,255,255,0.02)">
              <Icon name={p.icon} size={20} />
            </span>
            <h3 class="mt-4 text-xl text-ivory">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ivory-muted">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Built by Yashveer Labs -->
  <section class="section pt-0">
    <div class="container-nx">
      <div class="relative overflow-hidden rounded-[1.75rem] border border-line p-8 md:p-12">
        <div class="glow-radial"></div>
        <div class="relative grid items-center gap-10 lg:grid-cols-[1.4fr_1fr]">
          <div>
            <p class="eyebrow">Built by Yashveer Labs</p>
            <h2 class="mt-3 text-3xl md:text-4xl">A studio that refuses to compromise on quality</h2>
            <p class="mt-4 max-w-xl text-ivory-muted">Nexli is built by Yashveer Labs, a software studio founded on the belief that complex systems should be transparent, not opaque, and that the customer's success is the only real measure of the company's. Nexli is its first product, built deeply rather than broadly.</p>
            <a href="/founder" class="mt-6 inline-flex items-center gap-2 text-gold transition-transform hover:translate-x-1">
              Meet the founder <Icon name="arrow-right" size={18} />
            </a>
          </div>
          <div class="grid gap-4">
            {facts.map((f) => (
              <div class="flex items-baseline gap-4 border-b border-line pb-4 last:border-0 last:pb-0">
                <span class="font-display text-3xl text-gradient-gold">{f.k}</span>
                <span class="text-sm text-ivory-muted">{f.v}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    eyebrow="Join us early"
    title="Help shape the School Operating System"
    text="If this is the kind of system your school has been missing, we'd like to hear from you. Message us on WhatsApp, or explore the platform in the live demo."
  />
</BaseLayout>
