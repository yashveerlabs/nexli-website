---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";
import Icon from "../../components/Icon.astro";
import { SOLUTION_PAGES } from "../../lib/solutions";
import { webPage } from "../../lib/seo";

const title = "Solutions by school type";
const description =
  "Nexli adapts to how your school runs across CBSE, ICSE/CISCE, State Board, boarding and international schools, with configurable grading, roles and India-ready compliance.";
---
<BaseLayout title={title} description={description} jsonLd={webPage({ title, description, path: "/solutions" })}>
  <PageHero
    eyebrow="Solutions"
    title="Built to fit your kind of school"
    lead="Every school is different, with its own boards, sizes and structures. Because even Nexli's roles and grading are configurable, the platform adapts to you, not the other way around."
    breadcrumbs={[{ label: "Solutions" }]}
  />

  <section class="section">
    <div class="container-nx">
      <div class="grid gap-5 sm:grid-cols-2">
        {SOLUTION_PAGES.map((s, i) => (
          <a href={`/solutions/${s.slug}`} class={`card group reveal reveal-${(i % 4) + 1} block`}>
            <div class="flex items-start justify-between gap-3">
              <span class="inline-grid h-12 w-12 place-items-center rounded-xl border border-line text-gold" style="background:rgba(255,255,255,0.02)">
                <Icon name={s.icon} size={22} />
              </span>
              <Icon name="arrow-right" size={18} class="text-ivory-faint transition-all group-hover:translate-x-1 group-hover:text-gold" />
            </div>
            <h2 class="mt-4 text-xl text-ivory">{s.nav}</h2>
            <p class="mt-2 text-sm leading-relaxed text-ivory-muted">{s.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
