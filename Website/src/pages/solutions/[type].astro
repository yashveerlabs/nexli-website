---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import FeatureGrid from "../../components/FeatureGrid.astro";
import Faq from "../../components/Faq.astro";
import CtaBand from "../../components/CtaBand.astro";
import Icon from "../../components/Icon.astro";
import { SOLUTION_PAGES } from "../../lib/solutions";
import { MODULE_BY_SLUG } from "../../lib/modules";
import { KB_BY_SLUG } from "../../lib/site";
import { webPage } from "../../lib/seo";

export function getStaticPaths() {
  return SOLUTION_PAGES.map((s) => ({ params: { type: s.slug }, props: { s } }));
}
const { s } = Astro.props;
const path = `/solutions/${s.slug}`;
const modules = s.modules.map((m) => MODULE_BY_SLUG[m]).filter(Boolean);
const kbs = s.kb.map((k) => KB_BY_SLUG[k]).filter(Boolean);
---
<BaseLayout title={s.seoTitle} description={s.seoDescription} jsonLd={webPage({ title: s.seoTitle, description: s.seoDescription, path })}>
  <PageHero
    eyebrow="Solutions"
    title={s.title}
    lead={s.tagline}
    breadcrumbs={[{ label: "Solutions", href: "/solutions" }, { label: s.nav }]}
  >
    <a href="/demo" class="btn btn-gold">Try the live demo</a>
  </PageHero>

  <section class="section">
    <div class="container-nx">
      <div class="prose-nx mx-auto max-w-3xl">
        {s.intro.map((p) => <p>{p}</p>)}
      </div>
      <div class="mt-12">
        <p class="eyebrow">What matters most</p>
        <h2 class="reveal mt-3 text-3xl md:text-4xl">Built for {s.nav.toLowerCase()}</h2>
        <div class="mt-8">
          <FeatureGrid items={s.points} icon={s.icon} cols={2} />
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container-nx">
      <div class="rounded-[1.75rem] border border-line p-8 md:p-10">
        <p class="eyebrow">The modules you'll lean on</p>
        <h2 class="mt-3 text-2xl md:text-3xl">Where Nexli does the heavy lifting</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {modules.map((m) => (
            <a href={`/platform/${m.slug}`} class="flex items-center gap-3.5 rounded-xl border border-line p-4 transition-colors hover:border-gold/40">
              <span class="inline-grid h-10 w-10 shrink-0 place-items-center rounded-lg border border-line text-gold" style="background:rgba(255,255,255,0.02)">
                <Icon name={m.icon} size={19} />
              </span>
              <span>
                <span class="block text-ivory">{m.nav}</span>
                <span class="block text-xs text-ivory-faint">{m.summary}</span>
              </span>
            </a>
          ))}
        </div>
        {kbs.length > 0 && (
          <div class="mt-7 flex flex-wrap items-center gap-3 border-t border-line pt-6">
            <span class="text-sm text-ivory-faint">Related guides:</span>
            {kbs.map((k) => (
              <a href={`/knowledge-base/${k.slug}`} class="chip transition-colors hover:border-gold/40 hover:text-gold-200">
                <Icon name={k.icon} size={14} class="text-gold" /> {k.title}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <Faq items={s.faqs} title={`${s.nav}: common questions`} />

  <CtaBand />
</BaseLayout>
