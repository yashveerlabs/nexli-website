---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FloatingContact from "../components/FloatingContact.astro";
import { SITE, OG_IMAGE, SAME_AS, FOUNDER_SAME_AS } from "../lib/site";
import { ldJson } from "../lib/seo";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  /** Extra page-level JSON-LD (WebPage, Article, etc.). Object or array. */
  jsonLd?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description = SITE.description,
  image = OG_IMAGE,
  noindex = false,
  jsonLd,
} = Astro.props;
const extraJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

const pageTitle = title ? `${title} · ${SITE.name}` : `${SITE.name}: The School Operating System`;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL(image, SITE.url).href;
const ogImageType = /\.png$/i.test(image) ? "image/png" : "image/jpeg";
// Dimensions are known only for the default share image (1200x675); emit them so
// crawlers can lay out the card without fetching the file first.
const isDefaultOg = image === OG_IMAGE;

const orgJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: SITE.url,
  logo: new URL("/logo-full.jpg", SITE.url).href,
  image: ogImage,
  description: SITE.description,
  slogan: SITE.tagline,
  foundingDate: SITE.founded,
  areaServed: "Worldwide",
  founder: {
    "@type": "Person",
    name: SITE.founder,
    jobTitle: SITE.founderTitle,
    sameAs: FOUNDER_SAME_AS,
  },
  parentOrganization: { "@type": "Organization", name: SITE.company },
  sameAs: SAME_AS,
};
---
<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <!-- Mark JS as available before first paint so .reveal content (incl. the LCP
         hero) is hidden only when JS can animate it back in; no-JS paints it. -->
    <script is:inline>document.documentElement.classList.add("js");</script>

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta name="theme-color" content="#080808" />
    <link rel="icon" type="image/png" href="/logo-emblem.png" />
    <link rel="apple-touch-icon" href="/logo-emblem.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content={ogImageType} />
    {isDefaultOg && <meta property="og:image:width" content="1200" />}
    {isDefaultOg && <meta property="og:image:height" content="675" />}
    <meta property="og:image:alt" content={`${SITE.name}: ${SITE.tagline}`} />
    <meta property="og:locale" content={SITE.locale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${SITE.name}: ${SITE.tagline}`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap"
    />

    <script type="application/ld+json" set:html={ldJson(orgJsonLd)} is:inline />
    {extraJsonLd.map((block) => (
      <script type="application/ld+json" set:html={ldJson(block)} is:inline />
    ))}
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-gold focus:px-4 focus:py-2 focus:text-obsidian"
      >Skip to content</a
    >
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <FloatingContact />

    <script is:inline>
      (function () {
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const els = document.querySelectorAll(".reveal");
        if (reduce || !("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
